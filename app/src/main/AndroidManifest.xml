<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Overlay permission for drawing over other apps -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW"/>
    
    <!-- Foreground service for screen capture -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION"/>
    
    <!-- Wake lock to prevent CPU throttling during active use -->
    <uses-permission android:name="android.permission.WAKE_LOCK"/>

    <!-- Network access for GitHub-backed model store -->
    <uses-permission android:name="android.permission.INTERNET"/>
    
    <!-- Vulkan GPU feature — optional so the app still runs on devices without Vulkan -->
    <uses-feature android:name="android.hardware.vulkan.level" android:version="1" android:required="false"/>
    <uses-feature android:name="android.hardware.vulkan.version" android:version="0x00401000" android:required="false"/>
    
    <!-- OpenGL ES 3.1 required for the overlay renderer -->
    <uses-feature android:glEsVersion="0x00030001" android:required="true"/>

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AimBuddy"
        android:hardwareAccelerated="true">
        <!--
          extractNativeLibs="false": the OS memory-maps .so files directly from
          the APK instead of extracting them to disk. This reduces install size,
          speeds up first-launch and — critically — lowers resident memory because
          the OS can page-share mapped pages across processes.

          largeHeap="true" has been intentionally removed: NCNN/ImGui/Vulkan all
          use native (non-Java) heap, so enlarging the Java heap only increases GC
          overhead without benefiting the native side.
        -->

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="sensorLandscape"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:theme="@style/Theme.AimBuddy.Fullscreen">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <service
            android:name=".ScreenCaptureService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="mediaProjection" />

    </application>

</manifest>
